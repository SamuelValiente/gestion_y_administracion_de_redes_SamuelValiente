  reboot: inclusive
  refresh-installer:
    update: false
  interactive-sections: []
  locale: es_ES.UTF-8
  keyboard:
    layout: es
  identity:
    hostname: wp-node
    username: ansible
    # ansible
    password: "$6$oUoXDok513Bt8GTG$g6cjdRQ5ZonMftWJqsIpiFqdfZ3fqRdEBJ/DhYcOP1rSh7HFWQnKPX91Mh5FwpD8GbAbgVN7EYO7bNbgvcpNh1"
