upstream wordpress_swarm {
    server {{ nginx_swarm_host }}:{{ nginx_swarm_port }};

    keepalive 32;
}

server {
    listen 80;
    server_name {{ nginx_server_name }};

    # Logs
    access_log /var/log/nginx/wordpress_access.log;
    error_log  /var/log/nginx/wordpress_error.log;

    # Límite de subida (plugins, imágenes WordPress)
    client_max_body_size {{ nginx_client_max_body_size }};

    location / {
        proxy_pass         http://wordpress_swarm;
        proxy_http_version 1.1;

        # Headers para que WordPress sepa la IP real del cliente
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Timeouts
        proxy_read_timeout {{ nginx_proxy_read_timeout }};
        proxy_connect_timeout 10s;

        # Soporte keepalive con el upstream
        proxy_set_header   Connection "";
    }

    # Bloquear acceso directo a ficheros sensibles de WordPress
    location ~* /wp-config.php {
        deny all;
    }

    location ~* /xmlrpc.php {
        deny all;
    }
}